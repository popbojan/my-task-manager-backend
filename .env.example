# Production / Railway
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Set by Railway Postgres plugin (or paste manually)
DATABASE_URL=

# Auth secrets — generate strong random strings for production
JWT_SECRET=
OTP_SECRET=

# Frontend URL (Vite dev or deployed frontend origin)
CORS_ORIGIN=https://your-frontend.example.com

# SMTP (OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="My Task Manager <no-reply@example.com>"

# Optional: run prisma/seed.ts manually on Railway shell
SEED_USER_EMAIL=you@example.com
