# Production / Railway
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Set by Railway Postgres plugin (or paste manually)
DATABASE_URL=

# Auth secrets — generate strong random strings for production
JWT_SECRET=
OTP_SECRET=

# Frontend URL (Vite dev or deployed frontend origin)
CORS_ORIGIN=https://your-frontend.example.com

# OTP emails — Resend (recommended on Railway; uses HTTPS, not SMTP)
RESEND_API_KEY=
# Must be a verified sender in Resend (test: onboarding@resend.dev — only to your Resend account email)
MAIL_FROM=My Task Manager <onboarding@resend.dev>

# SMTP fallback when RESEND_API_KEY is unset (local dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Recurring task reset cron (daily at 00:00)
RECURRING_TASK_RESET_CRON_ENABLED=true
RECURRING_TASK_RESET_TZ=Europe/Berlin

# Optional: run prisma/seed.ts manually on Railway shell
SEED_USER_EMAIL=you@example.com
