generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  none
  important
  urgent
  important_urgent
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(none)
  deadline    DateTime?

  email       String

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([email])
  @@index([status])
  @@index([priority])
  @@index([deadline])
}

enum RecurringTaskStatus {
  todo
  in_progress
  done
}

enum RecurringFrequency {
  daily
  weekly
  monthly
}

model RecurringTask {
  id          String              @id @default(uuid())
  title       String
  description String?

  status      RecurringTaskStatus @default(todo)
  frequency   RecurringFrequency

  streakCount     Int       @default(0)
  lastCompletedAt DateTime?
  lastResetAt     DateTime?
  nextResetAt     DateTime

  email       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([frequency])
  @@index([nextResetAt])
}

model RecurringTaskProgress {
  id             String   @id @default(uuid())
  email          String   @unique

  allTasksStreak Int      @default(0)
  lastCheckedAt  DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}