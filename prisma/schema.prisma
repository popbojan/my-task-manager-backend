generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  none
  important
  urgent
  important_urgent
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(none)
  deadline    DateTime?

  email       String

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([email])
  @@index([status])
  @@index([priority])
  @@index([deadline])
}